# Copy this file to `.env` and uncomment what you want to set.
# `just` auto-loads `.env`, so any value here is picked up by `just rss-run`,
# `just rss-docker-run`, and `just rss-smoke`.
#
# Empty / unset variables fall back to the built-in defaults below.


# ---------------------------------------------------------------------------
# Public URL (the ONE you actually care about for self-hosting)
# ---------------------------------------------------------------------------
# When unset: feed + media URLs point at http://localhost:$PIRATEPOD_PORT
#             (fine for testing from the same machine)
# When set:   every <enclosure url="..."> in the RSS XML uses this URL, so
#             Apple Podcasts / Overcast / anyone in the world can stream.
#
# Workflow:
#   1.  just rss-run            # start the service on :8080
#   2.  just rss-tunnel         # in another shell — prints a trycloudflare URL
#   3.  Paste the printed URL below, restart rss-run, submit to Apple.
#
# PIRATEPOD_BASE_URL=https://your-subdomain.trycloudflare.com


# ---------------------------------------------------------------------------
# Everything else — defaults are fine for self-host; override only if needed
# ---------------------------------------------------------------------------

# Defaults to ${PIRATEPOD_BASE_URL}/media. Override if you serve media from
# a separate CDN domain (e.g. when you put the service behind nginx).
# PIRATEPOD_MEDIA_URL=https://cdn.example.com/piratepod

# PIRATEPOD_PORT=8080
# PIRATEPOD_SQLITE_PATH=./data/piratepod.db
# PIRATEPOD_MEDIA_DIR=./data/media


# ---------------------------------------------------------------------------
# Ingest worker
# ---------------------------------------------------------------------------
# Optional. Without a key, Jina Reader works at 20 RPM (rate-limited by IP).
# With a key, you get 500 RPM and per-key tracking. Get one at https://jina.ai/reader.
# JINA_API_KEY=jina_...


# ---------------------------------------------------------------------------
# Orchestrate worker
# ---------------------------------------------------------------------------
# Where orchestrate looks for its sibling workers. Defaults match the ports
# used by `just ingest-run` / `just scriptgen-run`, so leave unset for local
# dev. Override when a worker runs on a different host (e.g. staging).
# INGEST_URL=http://localhost:8001
# SCRIPTGEN_URL=http://localhost:8002
# AUDIOGEN_URL=http://localhost:8004
# RSS_URL=http://localhost:8080

# Per-call timeout (seconds) for orchestrate -> worker HTTP calls.
# ORCHESTRATE_HTTP_TIMEOUT=60

# Default self-host podcast created by orchestrate when RSS has no feed yet.
# PIRATEPOD_DEFAULT_TITLE=PiratePod
# PIRATEPOD_DEFAULT_DESCRIPTION=Generated episodes from PiratePod
# PIRATEPOD_DEFAULT_AUTHOR=
# PIRATEPOD_DEFAULT_LANGUAGE=en


# ---------------------------------------------------------------------------
# Audio generation worker
# ---------------------------------------------------------------------------
# llama-tts is a system binary from llama.cpp, not a uv/python dependency.
# Install it with: brew install llama.cpp
# LLAMA_TTS_BIN=llama-tts
# AUDIOGEN_OUTPUT_DIR=.piratepod/audio
# AUDIOGEN_TIMEOUT=600


# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------
# Set to 1 to also run live integration tests that hit real external services
# (e.g. r.jina.ai). Off by default so the suite is fast and offline.
# RUN_LIVE_TESTS=1
