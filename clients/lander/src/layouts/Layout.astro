---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PiratePod',
  description = 'Open-source, local-first AI podcast generator. All the magic of personalized podcasts, powered by local LLMs.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F5F4EF" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Instrument+Serif&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-bg text-fg antialiased font-mono">
    <slot />
  </body>
</html>
